  m_Name: 
  m_EditorClassIdentifier: 
  PluginText: "<ros2_control name=\"uf_robot_hardware/UFRobotSystemHardware\" type=\"system\">\n 
    <hardware>\n    <plugin>uf_robot_hardware/UFRobotSystemHardware</plugin>\n   
    <param name=\"hw_ns\">xarm</param>\n    <param name=\"velocity_control\">False</param>\n   
    <param name=\"prefix\">P</param>\n    <param name=\"robot_ip\">R</param>\n   
    <param name=\"report_type\">normal</param>\n    <param name=\"dof\">7</param>\n   
    <param name=\"baud_checkset\">True</param>\n    <param name=\"default_gripper_baud\">2000000</param>\n   
    <param name=\"robot_type\">xarm</param>\n    <param name=\"add_gripper\">False</param>\n   
    <param name=\"add_bio_gripper\">False</param>\n  </hardware>\n  <joint name=\"joint1\">\n   
    <command_interface name=\"position\">\n      <param name=\"min\">-6.283185307179586</param>\n     
    <param name=\"max\">6.283185307179586</param>\n    </command_interface>\n   
    <command_interface name=\"velocity\">\n      <param name=\"min\">-3.14</param>\n     
    <param name=\"max\">3.14</param>\n    </command_interface>\n    <state_interface
    name=\"position\" />\n    <state_interface name=\"velocity\" />\n    <!-- <state_interface
    name=\"effort\"/> -->\n  </joint>\n  <joint name=\"joint2\">\n    <command_interface
    name=\"position\">\n      <param name=\"min\">-2.059</param>\n      <param name=\"max\">2.0944</param>\n   
    </command_interface>\n    <command_interface name=\"velocity\">\n      <param
    name=\"min\">-3.14</param>\n      <param name=\"max\">3.14</param>\n    </command_interface>\n   
    <state_interface name=\"position\" />\n    <state_interface name=\"velocity\"
    />\n    <!-- <state_interface name=\"effort\"/> -->\n  </joint>\n  <joint name=\"joint3\">\n   
    <command_interface name=\"position\">\n      <param name=\"min\">-6.283185307179586</param>\n     
    <param name=\"max\">6.283185307179586</param>\n    </command_interface>\n   
    <command_interface name=\"velocity\">\n      <param name=\"min\">-3.14</param>\n     
    <param name=\"max\">3.14</param>\n    </command_interface>\n    <state_interface
    name=\"position\" />\n    <state_interface name=\"velocity\" />\n    <!-- <state_interface
    name=\"effort\"/> -->\n  </joint>\n  <joint name=\"joint4\">\n    <command_interface
    name=\"position\">\n      <param name=\"min\">-0.19198</param>\n      <param
    name=\"max\">3.927</param>\n    </command_interface>\n    <command_interface
    name=\"velocity\">\n      <param name=\"min\">-3.14</param>\n      <param name=\"max\">3.14</param>\n   
    </command_interface>\n    <state_interface name=\"position\" />\n    <state_interface
    name=\"velocity\" />\n    <!-- <state_interface name=\"effort\"/> -->\n  </joint>\n 
    <joint name=\"joint5\">\n    <command_interface name=\"position\">\n      <param
    name=\"min\">-6.283185307179586</param>\n      <param name=\"max\">6.283185307179586</param>\n   
    </command_interface>\n    <command_interface name=\"velocity\">\n      <param
    name=\"min\">-3.14</param>\n      <param name=\"max\">3.14</param>\n    </command_interface>\n   
    <state_interface name=\"position\" />\n    <state_interface name=\"velocity\"
    />\n    <!-- <state_interface name=\"effort\"/> -->\n  </joint>\n  <joint name=\"joint6\">\n   
    <command_interface name=\"position\">\n      <param name=\"min\">-1.69297</param>\n     
    <param name=\"max\">3.141592653589793</param>\n    </command_interface>\n   
    <command_interface name=\"velocity\">\n      <param name=\"min\">-3.14</param>\n     
    <param name=\"max\">3.14</param>\n    </command_interface>\n    <state_interface
    name=\"position\" />\n    <state_interface name=\"velocity\" />\n    <!-- <state_interface
    name=\"effort\"/> -->\n  </joint>\n  <joint name=\"joint7\">\n    <command_interface
    name=\"position\">\n      <param name=\"min\">-6.283185307179586</param>\n     
